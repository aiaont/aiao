
<rdf:RDF xmlns="http://w3id.org/aiao#"
		 xml:base="http://w3id.org/aiao"
		 xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
		 xmlns:owl="http://www.w3.org/2002/07/owl#"
		 xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
		 xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
		 xmlns:aiao="http://w3id.org/aiao#"
		 xmlns:lrml="http://docs.oasis-open.org/legalruleml/ns/v1.0/"
		 xmlns:prov="http://www.w3.org/ns/prov#"
		 xmlns:claimont="http://purl.org/claimont#"
		 xmlns:impactont="http://purl.org/impactont#"
		 xmlns:ruleml="http://www.ruleml.org/spec/"
		 xmlns:skos="http://www.w3.org/2004/02/skos/core#"
		 xmlns:terms="http://purl.org/dc/terms/"
		 xmlns:time="http://www.w3.org/2006/time#">
		 
	<!-- https://registry.goldstandard.org/projects/details/605 -->
	
	<owl:NamedIndividual rdf:ID="projectPeriod-gs3492">
		<time:hasBeginning rdf:resource="2010-01-01T00:00:00Z"/>
		<time:hasEnd rdf:resource="2037-12-31T23:59:59Z"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:ID="gs3492">
		<rdf:type rdf:resource="#Project"/>
		<comprisesActivity rdf:resource="gs3492-activity1"/>
		<comprisesActivity rdf:resource="gs3492-activity2"/>
		<comprisesActivity rdf:resource="gs3492-activity3"/>
		<hasObjective rdf:resource="Reduce the fuel consumption of ships through the application of advanced hull coatings."/>
		<hasDuration rdf:resource="projectPeriod-gs3492"/>
		<hasAgentActivityRelation rdf:resource="gs3492-agentActivityRel1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:ID="gs3492-activity1">
		<rdf:type rdf:resource="#Activity"/>
		<hasObjective rdf:resource="Apply Intersleek 700 (only) to selected vessels."/>		
	</owl:NamedIndividual>

	<owl:NamedIndividual rdf:ID="gs3492-activity2">
		<rdf:type rdf:resource="#Activity"/>
		<hasObjective rdf:resource="Apply Intersleek 700 and Intersleek 1100SR to selected vessels."/>		
	</owl:NamedIndividual>

	<owl:NamedIndividual rdf:ID="gs3492-activity3">
		<rdf:type rdf:resource="#Activity"/>
		<hasObjective rdf:resource="Apply Intersleek 900 (only) to selected vessels."/>		
	</owl:NamedIndividual>	
	
	<owl:NamedIndividual rdf:ID="internationalPaintLtd">
		<rdf:type rdf:resource="#Agent"/>
	</owl:NamedIndividual>		

	<owl:NamedIndividual rdf:ID="role-projectOwner">
		<rdf:type rdf:resource="#Role"/>
	</owl:NamedIndividual>	
	
	<owl:NamedIndividual rdf:ID="gs3492-agentActivityRel1">
		<rdf:type rdf:resource="#AgentActivityRelation"/>
		<hasAgent rdf:resource="internationalPaintLtd"/>
		<hasActivity rdf:resource="gs3492"/>
		<isGovernedBy rdf:resource="role-projectOwner"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:ID="ind-emissions-co2-ship">
		<rdf:type rdf:resource="impactont:Indicator"/>
		<hasDefinition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The amount of carbon dioxide (CO2) emissions released per year by a maritime vessel due to the fuel consumption of its engines.</hasDefinition>
		<hasUnitOfMeasure rdf:datatype="http://www.w3.org/2001/XMLSchema#string">tCO2/yr</hasUnitOfMeasure>
	</owl:NamedIndividual>	
	
	
	

	<!--For each of the 17 ships involved in the project, the following individuals must be created:-->
	
	<owl:NamedIndividual rdf:ID="ship9xxxx14-86366">
		<rdf:type rdf:resource="impactont:Thing"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:ID="voyageLog-ship9xxxx14-86366">
		<rdf:type rdf:resource="claimont:Substantiation"/>
	</owl:NamedIndividual>
	<!--A named individual like this must be created for each of the voyage logs of the ship.-->



	<owl:NamedIndividual rdf:ID="state-baseline-ship9xxxx14-86366-monper1">
		<rdf:type rdf:resource="impactont:State"/>
		<impactont:hasTemporalLocation rdf:resource="(10 September 2014 - 9 September 2015)"/>
		<impactont:hasModality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">counterfactual</hasModality>
		<impactont:isDefinedByIndicator rdf:resource="#ind-emissions-co2-ship">"/>
		<impactont:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">119000</hasValue>		
	</owl:NamedIndividual>	
	<!--A named individual like this must be created for each monitoring period.-->	
	
	<owl:NamedIndividual rdf:ID="claim-state-baseline-ship9xxxx14-86366-monper1">
		<rdf:type rdf:resource="#StateClaim"/>
		<claimont:hasClaimant rdf:resource="internationalPaintLtd"/>
		<claimont:hasSubject rdf:resource="ship9xxxx14-86366"/>
		<claimont:hasPredicate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Had baseline state during monitoring period 1 of gs3492-activity1</>
		<claimont:hasObject rdf:resource="state-baseline-ship9xxxx14-86366-monper1"/>
		<claimont:isSupportedBy rdf:resource="voyageLog-ship9xxxx14-86366"/>
	</owl:NamedIndividual>	
	<!--A named individual like this must be created for each monitoring period.-->
	
	
	
	<owl:NamedIndividual rdf:ID="state-project-ship9xxxx14-86366-monper1">
		<rdf:type rdf:resource="impactont:State"/>
		<impactont:hasTemporalLocation rdf:resource="(10 September 2014 - 9 September 2015)"/>
		<impactont:hasModality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">real</hasModality>
		<impactont:isDefinedByIndicator rdf:resource="#ind-emissions-co2-ship">"/>
		<impactont:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">101002</hasValue>		
	</owl:NamedIndividual>	  
	<!--A named individual like this must be created for each monitoring period.-->  
  
	<owl:NamedIndividual rdf:ID="claim-state-project-ship9xxxx14-86366-monper1">
		<rdf:type rdf:resource="#StateClaim"/>
		<claimont:hasClaimant rdf:resource="internationalPaintLtd"/>
		<claimont:hasSubject rdf:resource="ship9xxxx14-86366"/>
		<claimont:hasPredicate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Had project state during monitoring period 1 of gs3492-activity1</>
		<claimont:hasObject rdf:resource="state-project-ship9xxxx14-86366-monper1"/>
		<claimont:isSupportedBy rdf:resource="voyageLog-ship9xxxx14-86366"/>
	</owl:NamedIndividual>	  
	<!--A named individual like this must be created for each monitoring period.-->
  

  
	<owl:NamedIndividual rdf:ID="statediff-baselineVsProject-ship9xxxx14-86366-monper1">
        <rdf:type rdf:resource="impactont:Event"/>
		<impactont:hasStateA rdf:resource="state-baseline-ship9xxxx14-86366-monper1"/>
		<impactont:hasStateB rdf:resource="state-project-ship9xxxx14-86366-monper1"/>
    </owl:NamedIndividual>	  
	<!--A named individual like this must be created for each monitoring period.-->
  
  	<owl:NamedIndividual rdf:ID="claim-impact-project-ship9xxxx14-86366-monper1">
		<rdf:type rdf:resource="#ImpactClaim"/>
		<claimont:hasClaimant rdf:resource="internationalPaintLtd"/>
		<claimont:hasSubject rdf:resource="gs3492-activity1"/>
		<claimont:hasPredicate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">caused</>
		<claimont:hasObject rdf:resource="statediff-baselineVsProject-ship9xxxx14-86366-monper1"/>
		<claimont:isSupportedBy rdf:resource="...(#TODO: project documentation)..."/>
	</owl:NamedIndividual>	
	<!--A named individual like this must be created for each monitoring period.-->



	<owl:NamedIndividual rdf:ID="impact-project-ship9xxxx14-86366-monper1">
        <rdf:type rdf:resource="impactont:Impact"/>
		<impactont:hasStateA rdf:resource="state-baseline-ship9xxxx14-86366-monper1"/>
		<impactont:hasStateB rdf:resource="state-project-ship9xxxx14-86366-monper1"/>
		<impactont:hasProvenance rdf:resource="gs3492-activity1"/>
    </owl:NamedIndividual>	
	<!--A named individual like this must be created for each monitoring period for each ship.-->
 </rdf:RDF>