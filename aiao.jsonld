      {
        "@id": "http://w3id.org/aiao#Project"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "hasDuration"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2006/time#Duration"
      }
    ]
  },
  {
    "@id": "http://w3id.org/aiao#Activity",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A thing that an agent does, which impacts an environment."
      },
      {
        "@value": "An Activity may comprise other Activities."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Activity"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://w3id.org/impactont#Event"
      },
      {
        "@id": "_:N2d96ff27c63e49a9ab1aa062a85aed5d"
      },
      {
        "@id": "_:Nb5233c526fa44a26b6fbb609b695f17c"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "An event that is orchestrated by an agent."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@language": "en",
        "@value": "generating electricity"
      },
      {
        "@language": "en",
        "@value": "extracting minerals"
      },
      {
        "@language": "en",
        "@value": "protecting a forest"
      },
      {
        "@language": "en",
        "@value": "restoring a wetland"
      },
      {
        "@language": "en",
        "@value": "transporting goods"
      }
    ]
  },
  {
    "@id": "_:N2d96ff27c63e49a9ab1aa062a85aed5d",
    "@type": [
      "http://www.w3.org/2002/07/owl#Restriction"
    ],
    "http://www.w3.org/2002/07/owl#allValuesFrom": [
      {
        "@id": "http://w3id.org/aiao#Objective"
      }
    ],
    "http://www.w3.org/2002/07/owl#onProperty": [
      {
        "@id": "http://w3id.org/aiao#hasObjective"
      }
    ]
  },
  {
    "@id": "_:Nb5233c526fa44a26b6fbb609b695f17c",
    "@type": [
      "http://www.w3.org/2002/07/owl#Restriction"
    ],
    "http://www.w3.org/2002/07/owl#allValuesFrom": [
      {
        "@id": "http://w3id.org/aiao#AgentActivityRelation"
      }
    ],
    "http://www.w3.org/2002/07/owl#onProperty": [
      {
        "@id": "http://w3id.org/aiao#hasAgentActivityRelation"
      }
    ]
  },
  {
    "@id": "http://w3id.org/aiao#Instrument",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An Instrument may comprise other Instruments."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Instrument"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "A thing used to perform an activity, but which is neither an input to the activity, nor an output of the activity."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@language": "en",
        "@value": "boiler"
      },
      {
        "@language": "en",
        "@value": "truck"
      },
      {
        "@language": "en",
        "@value": "turbine"
      }
    ]
  },
  {
    "@id": "http://w3id.org/aiao#governs",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "http://w3id.org/aiao#Role"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "governs"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://w3id.org/aiao#AgentActivityRelation"
      }
    ],
    "http://www.w3.org/2002/07/owl#inverseOf": [
      {
        "@id": "http://w3id.org/aiao#isGovernedBy"
      }
    ]
  },
  {
    "@id": "http://w3id.org/aiao#ImpactClaim",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An Impact Claim may comprise other Impact Claims."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "ImpactClaim"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://w3id.org/claimont#Claim"
      },
      {
        "@id": "_:Nf35313795d284e01af5792baf00b5e30"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "A claim about the causal relation between an event and a state difference."
      }
    ]
  },
  {
    "@id": "_:Nf35313795d284e01af5792baf00b5e30",
    "@type": [
      "http://www.w3.org/2002/07/owl#Restriction"
    ],
    "http://www.w3.org/2002/07/owl#allValuesFrom": [
      {
        "@id": "http://w3id.org/impactont#Impact"
      }
    ],
    "http://www.w3.org/2002/07/owl#onProperty": [
      {
        "@id": "http://w3id.org/claimont#hasSubject"
      }
    ]
  },
  {
    "@id": "http://w3id.org/aiao#NaturalProcess",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "NaturalProcess"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://w3id.org/impactont#Process"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "A series of interrelated or interacting natural events without a primary human cause."
      }
    ]
  },
  {
    "@id": "http://w3id.org/aiao#hasAgent",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "http://w3id.org/aiao#AgentActivityRelation"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "hasAgent"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://w3id.org/aiao#Agent"
      }
    ]
  },
  {
    "@id": "http://w3id.org/aiao#comprisesActivity",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "http://w3id.org/aiao#Project"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "comprisesActivity"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://w3id.org/aiao#Activity"
      }
    ]
  },
  {
    "@id": "http://w3id.org/aiao#Control",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A Control may comprise other Controls, e.g., a methodology (a Control) defines many conditions to be met (which are Controls themselves)."
      },
      {
        "@value": "The implementation plan and monitoring plan for an activity are controls."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Control"
      }
    ],
    "http://www.w3.org/2002/07/owl#equivalentClass": [
      {
        "@id": "http://www.ruleml.org/spec/Rule"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "A thing that limits or directs another thing."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@language": "en",
        "@value": "implementation plan"
      },
      {
        "@language": "en",
        "@value": "monitoring plan"
      },
      {
        "@language": "en",
        "@value": "methodology"
      },
      {
        "@language": "en",
        "@value": "employment contract"
      }
    ]
  },
  {
    "@id": "http://w3id.org/aiao",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "en",
        "@value": "An ontology for accounting for how human activities impact their environments. \n\t\tThe premise of the ontology is: An agent engages in an activity that impacts an environment.\n\t\tThis ontology relies on the claimont, impactont and legalruleml ontologies."
      }
    ],
    "http://purl.org/dc/terms/title": [
      {
        "@language": "en",
        "@value": "Anthropogenic Impact Accounting Ontology"
      }
    ]
  },
  {
    "@id": "http://w3id.org/aiao#Project",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Project"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://w3id.org/impactont#Process"
      },
      {
        "@id": "_:N8afa6dbf15784f1c99da310c6f4d6b1a"
      },
      {
        "@id": "_:Ne6d70f22944e48658b05a56efa160e1e"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "A coordinated set of activities, subject to specific controls. The controls must include at least (a) an objective and (b) a limited duration."
      }
    ]
  },
  {
    "@id": "_:N8afa6dbf15784f1c99da310c6f4d6b1a",
    "@type": [
      "http://www.w3.org/2002/07/owl#Restriction"
    ],
    "http://www.w3.org/2002/07/owl#allValuesFrom": [
      {
        "@id": "http://w3id.org/aiao#Objective"
      }
    ],
    "http://www.w3.org/2002/07/owl#onProperty": [
      {
        "@id": "http://w3id.org/aiao#hasObjective"
      }
    ]
  },
  {
    "@id": "_:Ne6d70f22944e48658b05a56efa160e1e",
    "@type": [
      "http://www.w3.org/2002/07/owl#Restriction"
    ],
    "http://www.w3.org/2002/07/owl#allValuesFrom": [
      {
        "@id": "http://w3id.org/aiao#AgentActivityRelation"
      }
    ],
    "http://www.w3.org/2002/07/owl#onProperty": [
      {
        "@id": "http://w3id.org/aiao#hasAgentActivityRelation"
      }
    ]
  },
  {
    "@id": "_:Nb32bc051da7c47cd9dc45e8971c7b1ff",
    "@type": [
      "http://www.w3.org/2002/07/owl#AllDisjointClasses"
    ],
    "http://www.w3.org/2002/07/owl#members": [
      {
        "@list": [
          {
            "@id": "http://w3id.org/aiao#NaturalProcess"
          },
          {
            "@id": "http://w3id.org/aiao#Project"
          }
        ]
      }
    ]
  },
  {
    "@id": "http://w3id.org/aiao#StateClaim",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A State Claim may comprise other State Claims."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "StateClaim"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://w3id.org/claimont#Claim"
      },
      {
        "@id": "_:N824540ef88f64c8b8efa5875fbc8bf41"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "A claim about the state of a thing."
      }
    ]
  },
  {
    "@id": "_:N824540ef88f64c8b8efa5875fbc8bf41",
    "@type": [
      "http://www.w3.org/2002/07/owl#Restriction"
    ],
    "http://www.w3.org/2002/07/owl#allValuesFrom": [
      {
        "@id": "http://w3id.org/impactont#State"
      }
    ],
    "http://www.w3.org/2002/07/owl#onProperty": [
      {
        "@id": "http://w3id.org/claimont#hasSubject"
      }
    ]
  },
  {
    "@id": "http://w3id.org/aiao#Role",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The extent to which an agent is accountable for the impact of an activity is determined by the role that they fulfil(led) in the activity."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Role"
      }
    ],
    "http://www.w3.org/2002/07/owl#equivalentClass": [
      {
        "@id": "http://docs.oasis-open.org/legalruleml/ns/v1.0/Role"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "A control that specifies the scope of and/or requirements for an agent's relation to an activity."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@language": "en",
        "@value": "project developer"
      },
      {
        "@language": "en",
        "@value": "project owner"
      },
      {
        "@language": "en",
        "@value": "calibrator"
      },
      {
        "@language": "en",
        "@value": "operator"
      },
      {
        "@language": "en",
        "@value": "representer"
      }
    ]
  },
  {
    "@id": "http://w3id.org/aiao#AgentActivityRelation",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "AgentActivityRelation"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "The relation between an agent and an activity, typically governed by a formal control (such as an employment contract).\n\t\t"
      }
    ]
  },
  {
    "@id": "http://w3id.org/aiao#Objective",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Objective"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://w3id.org/aiao#Control"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@value": "Goal"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "A desired state to be effected by an activity."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@language": "en",
        "@value": "\"The objective of the activity is to apply Intersleek 700 to the hull of vessel 5514393.\""
      },
      {
        "@language": "en",
        "@value": "\"The objective of the project is to reduce the fuel consumption of our cargo fleet through the application of advanced hull coatings.\""
      }
    ]
  },
  {
    "@id": "http://w3id.org/aiao#Environment",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "This definition is not limited to physical or natural environments - social, political, economic, legal, etc. environments are also included."
      },
      {
        "@value": "An Environment may comprise other Environments."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Environment"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://w3id.org/impactont#Thing"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "The surroundings and conditions in which a thing occurs."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@language": "en",
        "@value": "The Manhattan Workaholics Support Group (a social environment)"
      },
      {
        "@language": "en",
        "@value": "The Republic of Indonesia (a political environment)"
      },
      {
        "@language": "en",
        "@value": "The economy of Australia (an economic environment)"
      },
      {
        "@language": "en",
        "@value": "A legal environment created by some set of consumer protection laws"
      },
      {
        "@language": "en",
        "@value": "Tribeca Mall (a physical environment)"
      },
      {
        "@language": "en",
        "@value": "Lake Victoria (a natural environment)"
      }
    ]
  },
  {
    "@id": "http://w3id.org/aiao#Agent",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "This class includes all kinds of human and human-comprised agents, such as natural persons, legal persons and cyber personas."
      },
      {
        "@value": "AIAO strongly recommends distinguishing between different types of agents (such as those listed above), but will neither require nor \n\t\tprescribe such distinctions."
      },
      {
        "@value": "An Agent may comprise other Agents."
      }
    ],
