    {
      "@id": "p5874:control/acm0002-v21",
      "@type": "aiao:Control",
      "rdfs:label": "ACM0002: Grid connected electricity generation from renewable sources (Version 21.0)",
      "dcterms:identifier": "ACM0002 v21.0",
      "dcterms:description": "Baseline and monitoring methodology applied to quantify emission reductions for a grid-connected renewable electricity generation project activity (solar PV) by comparing project electricity delivery against the counterfactual grid electricity generation it displaces."
    },
    
    {
      "@id": "p5874:control/tool-23-v03",
