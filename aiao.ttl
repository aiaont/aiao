@prefix : <http://w3id.org/aiao#> .
@prefix claimont: <http://w3id.org/claimont#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix impactont: <http://w3id.org/impactont#> .
@prefix lrml: <http://docs.oasis-open.org/legalruleml/ns/v1.0/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ruleml: <http://www.ruleml.org/spec/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .

<http://w3id.org/aiao> a owl:Ontology ;
    dcterms:description """An ontology for accounting for how human activities impact their environments. 
		The premise of the ontology is: An agent engages in an activity that impacts an environment.
		This ontology relies on the claimont, impactont and legalruleml ontologies."""@en ;
    dcterms:title "Anthropogenic Impact Accounting Ontology"@en .

:Environment a owl:Class ;
    rdfs:label "Environment"@en ;
    rdfs:comment "An Environment may comprise other Environments.",
        "This definition is not limited to physical or natural environments - social, political, economic, legal, etc. environments are also included." ;
    rdfs:subClassOf impactont:Thing ;
    skos:definition "The surroundings and conditions in which a thing occurs." ;
    skos:example "A legal environment created by some set of consumer protection laws"@en,
        "Lake Victoria (a natural environment)"@en,
        "The Manhattan Workaholics Support Group (a social environment)"@en,
        "The Republic of Indonesia (a political environment)"@en,
        "The economy of Australia (an economic environment)"@en,
        "Tribeca Mall (a physical environment)"@en .

:Role a owl:Class ;
    rdfs:label "Role"@en ;
    rdfs:comment "The extent to which an agent is accountable for the impact of an activity is determined by the role that they fulfil(led) in the activity." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom :AgentActivityRelation ;
            owl:onProperty :governs ],
        :Control ;
    owl:equivalentClass lrml:Role ;
    skos:definition "A control that specifies the scope of and/or requirements for an agent's relation to an activity." ;
    skos:example "calibrator"@en,
        "operator"@en,
        "project developer"@en,
        "project owner"@en,
        "representer"@en .

:StateProvenanceClaim a owl:Class ;
    rdfs:label "StateProvenanceClaim"@en ;
    rdfs:comment "A State Provenance Claim may comprise other State Provenance Claims." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom impactont:Event ;
            owl:onProperty claimont:hasObject ],
        [ a owl:Restriction ;
            owl:allValuesFrom impactont:State ;
            owl:onProperty claimont:hasSubject ],
        claimont:Claim ;
    skos:definition "A claim about the provenance of a state. 'hasPredicate' can only be 'impactont:hasProvenance'." .

:comprisesActivity a owl:ObjectProperty ;
    rdfs:label "comprisesActivity"@en ;
    rdfs:domain :Project ;
    rdfs:range :Activity .

:hasActivity a owl:ObjectProperty ;
    rdfs:label "hasActivity"@en ;
    rdfs:domain :AgentActivityRelation ;
    rdfs:range :Activity .

:hasAgent a owl:ObjectProperty ;
    rdfs:label "hasAgent"@en ;
    rdfs:domain :AgentActivityRelation ;
    rdfs:range :Agent .

:hasDuration a owl:ObjectProperty ;
    rdfs:label "hasDuration"@en ;
    rdfs:domain :Project ;
    rdfs:range time:Duration .

:isPerformedWith a owl:ObjectProperty ;
    rdfs:label "isPerformedWith"@en ;
    rdfs:domain :Activity ;
    rdfs:range :Instrument .

:Agent a owl:Class ;
    rdfs:label "Agent"@en ;
    rdfs:comment """AIAO strongly recommends distinguishing between different types of agents (such as those listed above), but will neither require nor 
		prescribe such distinctions.""",
        "An Agent may comprise other Agents.",
        "This class includes all kinds of human and human-comprised agents, such as natural persons, legal persons and cyber personas." ;
    rdfs:subClassOf lrml:Agent ;
    owl:equivalentClass prov:Agent ;
    skos:definition "A thing that bears some form of accountability for the occurrence of another thing." ;
    skos:example "Intermart Inc. (as a legal person)"@en,
        "Jane Doe (as a natural person)"@en,
        "User1234 on TalkSomeMore social media platform (as a cyber persona)"@en .

:ImpactClaim a owl:Class ;
    rdfs:label "ImpactClaim"@en ;
    rdfs:comment "An Impact Claim may comprise other Impact Claims." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom impactont:Impact ;
            owl:onProperty claimont:hasSubject ],
        claimont:Claim ;
    skos:definition "A claim about the causal relation between an event and a state difference." .

:Instrument a owl:Class ;
    rdfs:label "Instrument"@en ;
    rdfs:comment "An Instrument may comprise other Instruments." ;
    skos:definition "A thing used to perform an activity, but which is neither an input to the activity, nor an output of the activity." ;
    skos:example "boiler"@en,
        "truck"@en,
        "turbine"@en .

:NaturalProcess a owl:Class ;
    rdfs:label "NaturalProcess"@en ;
    rdfs:subClassOf impactont:Process ;
    skos:definition "A series of interrelated or interacting natural events without a primary human cause." .

:StateClaim a owl:Class ;
    rdfs:label "StateClaim"@en ;
    rdfs:comment "A State Claim may comprise other State Claims." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom impactont:State ;
            owl:onProperty claimont:hasSubject ],
        claimont:Claim ;
    skos:definition "A claim about the state of a thing." .

:governs a owl:ObjectProperty ;
    rdfs:label "governs"@en ;
    rdfs:domain :Control ;
    rdfs:range owl:Thing ;
    owl:inverseOf :isGovernedBy .

:Objective a owl:Class ;
    rdfs:label "Objective"@en ;
    rdfs:subClassOf :Control ;
    skos:altLabel "Goal" ;
    skos:definition "A desired state to be effected by an activity." ;
    skos:example "\"The objective of the activity is to apply Intersleek 700 to the hull of vessel 5514393.\""@en,
        "\"The objective of the project is to reduce the fuel consumption of our cargo fleet through the application of advanced hull coatings.\""@en .

:hasAgentActivityRelation a owl:ObjectProperty ;
    rdfs:label "hasAgentActivityRelation"@en ;
    rdfs:comment "This property is used on the Activity and Project classes. The range should always be an AgentActivityRelation. This is enforced by owl:Restriction (see the definitions of the Activity and Project classes.)" .

:hasObjective a owl:ObjectProperty ;
    rdfs:label "hasObjective"@en ;
    rdfs:comment "This property is used on the Activity and Project classes. The range should always be an Objective. This is enforced by owl:Restriction (see the definitions of the Activity and Project classes.)" .

:Activity a owl:Class ;
    rdfs:label "Activity"@en ;
    rdfs:comment "A thing that an agent does, which impacts an environment.",
        "An Activity may comprise other Activities." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom :Objective ;
            owl:onProperty :hasObjective ],
        [ a owl:Restriction ;
            owl:allValuesFrom :AgentActivityRelation ;
            owl:onProperty :hasAgentActivityRelation ],
        impactont:Event ;
    skos:definition "An event that is orchestrated by an agent." ;
    skos:example "extracting minerals"@en,
        "generating electricity"@en,
        "protecting a forest"@en,
        "restoring a wetland"@en,
        "transporting goods"@en .

:Control a owl:Class ;
    rdfs:label "Control"@en ;
    rdfs:comment "A Control may comprise other Controls, e.g., a methodology (a Control) defines many conditions to be met (which are Controls themselves).",
        "The implementation plan and monitoring plan for an activity are controls." ;
    owl:equivalentClass ruleml:Rule ;
    skos:definition "A thing that limits or directs another thing." ;
    skos:example "employment contract"@en,
        "implementation plan"@en,
        "methodology"@en,
        "monitoring plan"@en .

:Project a owl:Class ;
    rdfs:label "Project"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom :AgentActivityRelation ;
            owl:onProperty :hasAgentActivityRelation ],
        [ a owl:Restriction ;
            owl:allValuesFrom :Objective ;
            owl:onProperty :hasObjective ],
        impactont:Process ;
    skos:definition "A coordinated set of activities, subject to specific controls. The controls must include at least (a) an objective and (b) a limited duration." .

:AgentActivityRelation a owl:Class ;
    rdfs:label "AgentActivityRelation"@en ;
    skos:definition """The relation between an agent and an activity, typically governed by a formal control (such as an employment contract).
		""" .

[] a owl:AllDisjointClasses ;
    owl:members ( :NaturalProcess :Project ) .

[] a owl:AllDisjointClasses ;
    owl:members ( :ImpactClaim :StateClaim ) .

